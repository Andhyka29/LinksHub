<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="icon" type="image/png" href="/favicon.png">
    <title>LinkHub</title>
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #1c1c1e 0%, #2c2c2e 50%, #1c1c1e 100%);
            --card-bg: #242425c0;
            --text-primary: #f5f5f7;
            --text-secondary: #8e8e93;
            --accent-red: #e74c3c;
            --border: rgba(255,255,255,0.08);
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", system-ui, sans-serif;
            background: var(--bg-gradient);
            color: var(--text-primary);
            min-height: 100vh;
        }
        .navbar {
            background: rgba(31, 31, 32, 0.74);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(20px);
        }
        .card {
            background: var(--card-bg);
            border-radius: 16px;
            border: 1px solid var(--border);
        }
        .input-field {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px;
            color: var(--text-primary);
            transition: all 0.15s ease;
        }
        .input-field::placeholder {
            color: var(--text-secondary);
        }
        .input-field:focus {
            outline: none;
            border-color: var(--accent-red);
            box-shadow: 0 0 0 2px rgba(231, 76, 60, 0.2);
        }
        .btn-primary {
            background: var(--accent-red);
            border-radius: 980px;
            font-weight: 600;
            transition: all 0.15s ease;
        }
        .btn-primary:hover {
            opacity: 0.9;
        }
        .link-item {
            background: rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 14px;
            transition: all 0.15s ease;
        }
        .link-item:hover {
            background: rgba(255,255,255,0.08);
        }
        .link-item-sm {
            padding: 10px;
        }
        .category-header {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 0.5rem;
            margin-bottom: 0.75rem;
        }
        .badge-category {
            background: var(--accent-red);
            color: white;
            font-size: 10px;
            font-weight: 600;
            padding: 0.25rem 0.6rem;
            border-radius: 980px;
            text-transform: uppercase;
        }
        .icon-btn {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.15s ease;
        }
        .icon-btn:hover {
            background: rgba(255,255,255,0.1);
        }
        @media (max-width: 768px) {
            .link-item {
                padding: 10px;
            }
            .max-h-links {
                max-height: none;
            }
        }
    </style>
</head>

<body class="min-h-screen flex flex-col">
    <!-- Header/Navbar -->
    <header class="navbar px-4 sm:px-6 py-3 sm:py-4 flex justify-between items-center">
        <div class="flex items-center gap-2">
            <img src="/logo.png" alt="LinkHub Logo" width="32" height="32">
            <h1 class="text-lg sm:text-xl font-semibold text-white">LinkHub</h1>
        </div>
        <a href="/logout" class="text-gray-400 hover:text-white transition-colors text-xs sm:text-sm">Logout</a>
    </header>

    <!-- Main Content - Responsive Layout -->
    <div class="flex-1 flex flex-col lg:flex-row gap-4 lg:gap-6 p-4 sm:p-6 max-w-6xl mx-auto w-full">
        <!-- Left Column - Add Link Form -->
        <div class="w-full lg:w-96">
            <div class="card p-4 sm:p-6">
                <h2 class="text-base sm:text-lg font-semibold text-white mb-3 sm:mb-4">Add New Link</h2>
                
                <form action="/add" method="POST" class="space-y-3 sm:space-y-4">
                    <input name="title" placeholder="Title" class="input-field w-full h-12 sm:h-auto py-3 px-4 outline-none" required>
                    <input name="url" placeholder="URL" class="input-field w-full h-12 sm:h-auto py-3 px-4 outline-none" required>
                    
                    <div>
                        <select id="categorySelect" name="category" class="input-field w-full h-12 sm:h-auto py-3 px-4 appearance-none cursor-pointer bg-[rgba(255,255,255,0.08)]" onchange="toggleOtherInput()">
                            <option value="" class="text-black">Select Category</option>
                            <option value="Personal" class="text-black">Personal</option>
                            <option value="Work" class="text-black">Work</option>
                            <option value="Entertainment" class="text-black">Entertainment</option>
                            <option value="Social Media" class="text-black">Social Media</option>
                            <option value="Other" class="text-black">Other</option>
                        </select>
                        <input type="text" id="categoryOther" placeholder="Enter category..." class="input-field w-full h-12 sm:h-auto py-3 outline-none mt-2 hidden">
                    </div>

                    <button class="btn-primary text-white h-12 sm:h-auto py-3 w-full">
                        Add Link
                    </button>
                </form>
            </div>
        </div>

        <!-- Right Column - Link List -->
        <div class="flex-1 w-full">
            <div class="card p-4 sm:p-6">
                <h2 class="text-base sm:text-lg font-semibold text-white mb-3 sm:mb-4">Your Links</h2>
                
                <div class="space-y-4 sm:space-y-6 max-h-links overflow-y-auto">
                    <% 
                    const categoryOrder = { 'Personal': 1, 'Work': 2, 'Entertainment': 3, 'Social Media': 4, 'Other': 5 };
                    const grouped = {};
                    links.forEach(link => {
                        const cat = link.category || 'Other';
                        if (!grouped[cat]) grouped[cat] = [];
                        grouped[cat].push(link);
                    });
                    const sortedCategories = Object.keys(grouped).sort((a, b) => (categoryOrder[a] || 99) - (categoryOrder[b] || 99));
                    %>
                    
                    <% sortedCategories.forEach(cat => { %>
                    <div>
                        <h3 class="category-header"><%= cat %></h3>
                        <div class="space-y-2">
                            <% grouped[cat].forEach(link => { %>
                            <div class="link-item flex justify-between items-center">
                                <!-- Kiri: judul bisa diklik seluruh area -->
                                <a href="<%= link.url %>" target="_blank" class="flex-1 block">
                                    <p class="font-bold text-white uppercase text-sm transition-colors">
                                        <%= link.title %>
                                    </p>
                                    <span class="badge-category"><%= link.category %></span>
                                </a>

                                <!-- Kanan: tombol aksi -->
                                <div class="flex gap-1">
                                    <a href="/favorite/<%= link.id %>" class="icon-btn text-yellow-400">⭐</a>
                                    <a href="/edit/<%= link.id %>" class="icon-btn text-blue-400">✏️</a>
                                    <a href="/delete/<%= link.id %>" class="icon-btn text-red-400">🗑</a>
                                </div>
                            </div>
                            <% }) %>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleOtherInput() {
            const select = document.getElementById('categorySelect');
            const otherInput = document.getElementById('categoryOther');
            if (select.value === 'Other') {
                otherInput.classList.remove('hidden');
                otherInput.required = true;
                select.name = '';
                otherInput.name = 'category';
            } else {
                otherInput.classList.add('hidden');
                otherInput.required = false;
                otherInput.value = '';
                select.name = 'category';
                otherInput.name = '';
            }
        }
    </script>
</body>
</html>