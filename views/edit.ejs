<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="icon" type="image/png" href="/favicon.png">
    <title>Edit Link</title>
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #1c1c1e 0%, #2c2c2e 50%, #1c1c1e 100%);
            --card-bg: #2c2c2e;
            --text-primary: #f5f5f7;
            --text-secondary: #8e8e93;
            --accent-red: #e74c3c;
            --border: rgba(255,255,255,0.08);
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", system-ui, sans-serif;
            background: var(--bg-gradient);
            color: var(--text-primary);
            min-height: 100vh;
        }
        .card {
            background: var(--card-bg);
            border-radius: 16px;
            border: 1px solid var(--border);
        }
        .input-field {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px;
            color: var(--text-primary);
            transition: all 0.15s ease;
        }
        .input-field::placeholder {
            color: var(--text-secondary);
        }
        .input-field:focus {
            outline: none;
            border-color: var(--accent-red);
            box-shadow: 0 0 0 2px rgba(231, 76, 60, 0.2);
        }
        .btn-primary {
            background: var(--accent-red);
            border-radius: 980px;
            font-weight: 600;
            transition: all 0.15s ease;
        }
        .btn-primary:hover {
            opacity: 0.9;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">
    <!-- Header/Navbar -->
    <header class="bg-[rgba(44,44,46,0.9)] backdrop-blur-[20px] px-4 sm:px-6 py-3 sm:py-4 flex justify-between items-center">
        <h1 class="text-lg sm:text-xl font-semibold text-white">🔗 LinkHub</h1>
        <a href="/logout" class="text-gray-400 hover:text-white transition-colors text-xs sm:text-sm">Logout</a>
    </header>

    <!-- Main Content -->
    <div class="flex-1 flex justify-center items-center p-4 sm:p-6">
        <div class="card w-full max-w-[400px] px-4 py-5 sm:px-6 sm:py-6">
            <h1 class="text-xl sm:text-2xl font-semibold mb-4 sm:mb-6 text-white">✏️ Edit Link</h1>

            <form action="/edit/<%= link.id %>" method="POST" class="space-y-3 sm:space-y-4">
                <input name="title" value="<%= link.title %>" 
                    class="input-field w-full h-12 sm:h-auto py-3 outline-none" required>
                <input name="url" value="<%= link.url %>" 
                    class="input-field w-full h-12 sm:h-auto py-3 outline-none" required>
                
                <div>
                    <select id="categorySelect" name="category" class="input-field w-full h-12 sm:h-auto py-3 appearance-none cursor-pointer bg-[rgba(255,255,255,0.08)]" onchange="toggleOtherInput()">
                        <option value="" class="text-black">Select Category</option>
                        <option value="Personal" <%= link.category === 'Personal' ? 'selected' : '' %> class="text-black">Personal</option>
                        <option value="Work" <%= link.category === 'Work' ? 'selected' : '' %> class="text-black">Work</option>
                        <option value="Entertainment" <%= link.category === 'Entertainment' ? 'selected' : '' %> class="text-black">Entertainment</option>
                        <option value="Social Media" <%= link.category === 'Social Media' ? 'selected' : '' %> class="text-black">Social Media</option>
                        <option value="Other" <%= !['Personal','Work','Entertainment','Social Media'].includes(link.category) && link.category ? 'selected' : '' %> class="text-black">Other</option>
                    </select>
                    <input type="text" id="categoryOther" name="<%= !['Personal','Work','Entertainment','Social Media'].includes(link.category) && link.category ? 'category' : '' %>" placeholder="Enter category..." class="input-field w-full h-12 sm:h-auto py-3 outline-none mt-2 <%= !['Personal','Work','Entertainment','Social Media'].includes(link.category) && link.category ? '' : 'hidden' %>" value="<%= !['Personal','Work','Entertainment','Social Media'].includes(link.category) && link.category ? link.category : '' %>">
                </div>

                <button class="btn-primary text-white h-12 sm:h-auto py-3 w-full">
                    Save Changes
                </button>
            </form>
            
            <a href="/" class="block text-center text-gray-400 mt-3 sm:mt-4 hover:text-white transition-colors text-sm">Cancel</a>
        </div>
    </div>

    <script>
        function toggleOtherInput() {
            const select = document.getElementById('categorySelect');
            const otherInput = document.getElementById('categoryOther');
            if (select.value === 'Other') {
                otherInput.classList.remove('hidden');
                otherInput.required = true;
                select.name = '';
                otherInput.name = 'category';
            } else {
                otherInput.classList.add('hidden');
                otherInput.required = false;
                otherInput.value = '';
                select.name = 'category';
                otherInput.name = '';
            }
        }
    </script>
</body>
</html>